<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Power BI Token List View -->
    <record id="view_api_connector_list" model="ir.ui.view">
        <field name="name">api.connector.list</field>
        <field name="model">api.connector</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_id"/>
                <field name="field_ids"/>
                <field name="used_for"/>
            </list>
        </field>
    </record>

    <!-- Power BI Token Form View -->
    <record id="view_api_connector_form" model="ir.ui.view">
        <field name="name">api.connector.form</field>
        <field name="model">api.connector</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_id"/>
                            <field name="field_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="used_for"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_api_connector_action" model="ir.actions.act_window">
        <field name="name">API Connectors</field>
        <field name="res_model">api.connector</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>