<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="api_token_expiry_reminder" model="ir.cron">
            <field name="name">API Token Expiry</field>
            <field name="model_id" ref="st_api_connector.model_api_token"/>
            <field name="state">code</field>
            <field name="code">model._update_nextcall()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
